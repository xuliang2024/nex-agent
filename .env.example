# =====================================================
# Nex Agent — Environment Variables (template)
# Copy this file to `.env` and fill in your own keys.
# .env is gitignored and will NEVER be committed.
# =====================================================

# ---- Required for built-in image / video / TTS skills ----
# NEX AI (xskill.ai) API key. Sign up at https://xskill.ai
# Or sign in inside the app and the key will be auto-fetched.
SUTUI_API_KEY=

# ---- Required for the Agent LLM ----
# OpenRouter-compatible API key for the agent LLM.
# Use NEX AI (https://api.xskill.ai) or your own OpenRouter key.
OPENROUTER_API_KEY=

# =====================================================
# Optional — only needed when you build & notarize the
# macOS .dmg yourself with electron-builder.
# Leave empty to skip code-signing & notarization.
# =====================================================

# Apple Developer ID identity used for code-signing the .app
# e.g. "Developer ID Application: Your Name (TEAMID)"
# CSC_NAME=

# Apple ID credentials for notarization (set together)
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
